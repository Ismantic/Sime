#!/bin/sh
set -e

APP="/Library/Input Methods/SimeIME.app"
BUNDLE_ID="com.sime.inputmethod.SimeIME"
LSREG=/System/Library/Frameworks/CoreServices.framework/Frameworks/LaunchServices.framework/Support/lsregister

# Strip xattrs that can confuse the system on a fresh install.
xattr -dr com.apple.quarantine "$APP" 2>/dev/null || true
xattr -dr com.apple.provenance "$APP" 2>/dev/null || true

# Re-register the bundle with LaunchServices.
"$LSREG" -f "$APP" || true

# Kill any old SimeIME process so the new bundle is the one that gets launched.
pkill -x SimeIME 2>/dev/null || true

CONSOLE_USER=$(stat -f%Su /dev/console)
CONSOLE_UID=$(id -u "$CONSOLE_USER" 2>/dev/null || echo "")

if [ -n "$CONSOLE_USER" ] && [ "$CONSOLE_USER" != "root" ] && [ -n "$CONSOLE_UID" ]; then
  PLIST="/Users/$CONSOLE_USER/Library/Preferences/com.apple.HIToolbox.plist"

  # Dedupe Sime entries in AppleEnabledInputSources — duplicates trigger a
  # CFRelease(NULL) crash inside TextInputUIMacHelper on macOS 26.
  if [ -f "$PLIST" ]; then
    /usr/bin/python3 - "$PLIST" "$BUNDLE_ID" <<'PYEOF' || true
import plistlib, sys
path, bid = sys.argv[1], sys.argv[2]
with open(path, 'rb') as f:
    data = plistlib.load(f)
src_list = data.get('AppleEnabledInputSources') or []
seen = set()
deduped = []
for src in src_list:
    if src.get('Bundle ID') == bid:
        key = (src.get('Bundle ID'), src.get('Input Mode'))
        if key in seen:
            continue
        seen.add(key)
    deduped.append(src)
if len(deduped) != len(src_list):
    data['AppleEnabledInputSources'] = deduped
    with open(path, 'wb') as f:
        plistlib.dump(data, f)
PYEOF
    chown "$CONSOLE_USER" "$PLIST" 2>/dev/null || true
  fi

  # Bounce the IM launch agent so the new bundle is picked up cleanly.
  launchctl asuser "$CONSOLE_UID" \
    launchctl kickstart -k "gui/$CONSOLE_UID/com.apple.imklaunchagent" \
    >/dev/null 2>&1 || true
fi

# Refresh menu bar / preferences daemon.
killall cfprefsd TextInputMenuAgent TextInputSwitcher SystemUIServer 2>/dev/null || true

exit 0
