pkgname=fcitx5-sime
pkgver=2026.03.31
pkgrel=1
pkgdesc="Sime Chinese input method for Fcitx5"
arch=("x86_64")
url="https://github.com/Ismantic/Sime"
license=("custom")
depends=("fcitx5")
makedepends=("cmake" "gcc" "make")
source=("sime::git+https://github.com/Ismantic/Sime"
        "https://github.com/Ismantic/Sime/releases/download/v${pkgver}/trie.bin"
        "https://github.com/Ismantic/Sime/releases/download/v${pkgver}/model.bin")
sha256sums=("SKIP" "SKIP" "SKIP")

build() {
  cmake -S "$srcdir/sime" -B "$srcdir/build" \
    -DCMAKE_BUILD_TYPE=Release \
    -DSIME_ENABLE_FCITX5=ON
  cmake --build "$srcdir/build"
}

package() {
  DESTDIR="$pkgdir" cmake --install "$srcdir/build"

  install -dm755 "$pkgdir/usr/share/sime"
  install -m644 "$srcdir/trie.bin"  "$pkgdir/usr/share/sime/trie.bin"
  install -m644 "$srcdir/model.bin" "$pkgdir/usr/share/sime/model.bin"
}
