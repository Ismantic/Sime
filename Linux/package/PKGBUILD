pkgname=fcitx5-sime
pkgver=2026.04.14
pkgrel=1
pkgdesc="Sime Chinese input method for Fcitx5"
arch=("x86_64")
url="https://github.com/Ismantic/Sime"
license=("Apache-2.0")
depends=("fcitx5")
makedepends=("cmake" "gcc" "make")
source=()
sha256sums=()

_srcdir="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"

build() {
  cmake -S "$_srcdir" -B "$srcdir/build" \
    -DCMAKE_BUILD_TYPE=Release \
    -DSIME_ENABLE_FCITX5=ON
  cmake --build "$srcdir/build"
}

package() {
  DESTDIR="$pkgdir" cmake --install "$srcdir/build"

  install -dm755 "$pkgdir/usr/share/sime"
  install -m644 "$_srcdir/pipeline/output/sime.dict" "$pkgdir/usr/share/sime/sime.dict"
  install -m644 "$_srcdir/pipeline/output/sime.cnt"  "$pkgdir/usr/share/sime/sime.cnt"
}
