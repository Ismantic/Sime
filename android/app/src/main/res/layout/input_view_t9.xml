<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/keyboard_bg">

    <!-- Preedit -->
    <TextView
        android:id="@+id/preedit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="@color/preedit_text"
        android:background="@color/candidate_bg"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        android:visibility="gone" />

    <!-- Toolbar: [settings] [candidate bar] -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:background="@color/candidate_bg">

        <!-- Settings button -->
        <TextView
            android:layout_width="40dp"
            android:layout_height="match_parent"
            android:text="⚙"
            android:tag="settings_open"
            android:textSize="20sp"
            android:gravity="center"
            android:textColor="@color/key_text_secondary" />

        <!-- Candidate bar -->
        <HorizontalScrollView
            android:id="@+id/candidate_scroll"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:scrollbars="none">
            <LinearLayout
                android:id="@+id/candidate_container"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="4dp"
                android:paddingEnd="4dp" />
        </HorizontalScrollView>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/candidate_divider" />

    <!-- Main T9 area: 5 columns × 3 rows -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="6dp"
        android:paddingBottom="3dp">

        <!-- Left column: punctuation / pinyin candidates -->
        <LinearLayout
            android:id="@+id/t9_left_col"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.9"
            android:orientation="vertical"
            android:layout_marginEnd="3dp"
            android:background="@drawable/key_bg"
            android:gravity="center" />

        <!-- Center 3×3 T9 keys -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="3.3"
            android:orientation="vertical">

            <!-- Row 1: 分词 ABC DEF -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:paddingBottom="3dp">
                <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                    android:text="分词" android:tag="t9_fenci"
                    android:textSize="15sp" android:gravity="center"
                    android:background="@drawable/key_bg" android:layout_marginStart="3dp" android:layout_marginEnd="3dp" android:textColor="@color/key_text" />
                <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                    android:text="ABC" android:tag="t9_2"
                    android:textSize="16sp" android:gravity="center"
                    android:background="@drawable/key_bg" android:layout_marginStart="3dp" android:layout_marginEnd="3dp" android:textColor="@color/key_text" />
                <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                    android:text="DEF" android:tag="t9_3"
                    android:textSize="16sp" android:gravity="center"
                    android:background="@drawable/key_bg" android:layout_marginStart="3dp" android:layout_marginEnd="3dp" android:textColor="@color/key_text" />
            </LinearLayout>

            <!-- Row 2: GHI JKL MNO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:paddingBottom="3dp">
                <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                    android:text="GHI" android:tag="t9_4"
                    android:textSize="16sp" android:gravity="center"
                    android:background="@drawable/key_bg" android:layout_marginStart="3dp" android:layout_marginEnd="3dp" android:textColor="@color/key_text" />
                <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                    android:text="JKL" android:tag="t9_5"
                    android:textSize="16sp" android:gravity="center"
                    android:background="@drawable/key_bg" android:layout_marginStart="3dp" android:layout_marginEnd="3dp" android:textColor="@color/key_text" />
                <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                    android:text="MNO" android:tag="t9_6"
                    android:textSize="16sp" android:gravity="center"
                    android:background="@drawable/key_bg" android:layout_marginStart="3dp" android:layout_marginEnd="3dp" android:textColor="@color/key_text" />
            </LinearLayout>

            <!-- Row 3: PQRS TUV WXYZ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                    android:text="PQRS" android:tag="t9_7"
                    android:textSize="16sp" android:gravity="center"
                    android:background="@drawable/key_bg" android:layout_marginStart="3dp" android:layout_marginEnd="3dp" android:textColor="@color/key_text" />
                <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                    android:text="TUV" android:tag="t9_8"
                    android:textSize="16sp" android:gravity="center"
                    android:background="@drawable/key_bg" android:layout_marginStart="3dp" android:layout_marginEnd="3dp" android:textColor="@color/key_text" />
                <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                    android:text="WXYZ" android:tag="t9_9"
                    android:textSize="16sp" android:gravity="center"
                    android:background="@drawable/key_bg" android:layout_marginStart="3dp" android:layout_marginEnd="3dp" android:textColor="@color/key_text" />
            </LinearLayout>
        </LinearLayout>

        <!-- Right column: backspace, 重输, @ -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.9"
            android:orientation="vertical"
            android:layout_marginStart="3dp">

            <ImageView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
                android:src="@drawable/ic_backspace" android:tag="backspace"
                android:scaleType="center"
                android:background="@drawable/key_bg_dark" android:layout_marginBottom="3dp" />
            <TextView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
                android:text="重输" android:tag="t9_clear"
                android:textSize="13sp" android:gravity="center"
                android:background="@drawable/key_bg_dark" android:layout_marginBottom="3dp" android:textColor="@color/key_text_secondary" />
            <TextView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
                android:text="\@" android:tag="sym_@"
                android:textSize="18sp" android:gravity="center"
                android:background="@drawable/key_bg_dark" android:textColor="@color/key_text_secondary" />
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom row: [26] [?123] [space] [中/英] [enter] -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:paddingStart="3dp"
        android:paddingEnd="3dp"
        android:paddingTop="3dp"
        android:paddingBottom="8dp">
        <TextView
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="0.9"
            android:text="符号" android:tag="sym_open"
            android:textSize="13sp" android:gravity="center"
            android:background="@drawable/key_bg_dark" android:layout_marginStart="2.5dp" android:layout_marginEnd="2.5dp" android:textColor="@color/key_text_secondary" />
        <TextView
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:text="\?123" android:tag="num_open"
            android:textSize="13sp" android:gravity="center"
            android:background="@drawable/key_bg_dark" android:layout_marginStart="2.5dp" android:layout_marginEnd="2.5dp" android:textColor="@color/key_text_secondary" />
        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="3"
            android:tag="space"
            android:textSize="14sp" android:gravity="center"
            android:background="@drawable/key_bg" android:layout_marginStart="2.5dp" android:layout_marginEnd="2.5dp" android:textColor="@color/key_text_secondary" />
        <TextView
            android:id="@+id/key_toggle"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:text="中" android:tag="toggle"
            android:textSize="15sp" android:gravity="center"
            android:background="@drawable/key_bg_dark" android:layout_marginStart="2.5dp" android:layout_marginEnd="2.5dp" android:textColor="@color/key_text_secondary" />
        <ImageView
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.3"
            android:src="@drawable/ic_enter" android:tag="enter"
            android:scaleType="center"
            android:background="@drawable/key_bg_accent" android:layout_marginStart="2.5dp" android:layout_marginEnd="2.5dp" />
    </LinearLayout>

</LinearLayout>
