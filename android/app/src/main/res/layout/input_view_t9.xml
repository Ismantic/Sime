<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/keyboard_bg">

    <!-- Preedit -->
    <TextView
        android:id="@+id/preedit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="@color/preedit_text"
        android:background="@color/candidate_bg"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        android:visibility="gone" />

    <!-- Candidate bar -->
    <HorizontalScrollView
        android:id="@+id/candidate_scroll"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:scrollbars="none"
        android:background="@color/candidate_bg">
        <LinearLayout
            android:id="@+id/candidate_container"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="4dp" />
    </HorizontalScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/candidate_divider" />

    <!-- Row 1: 1  2(abc)  3(def) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="6dp"
        android:paddingBottom="3dp">

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:background="@drawable/key_bg" android:layout_marginStart="3dp" android:layout_marginEnd="3dp"
            android:tag="t9_1" android:clickable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="1" android:textSize="22sp" android:textColor="@color/key_text" android:clickable="false" />
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:background="@drawable/key_bg" android:layout_marginStart="3dp" android:layout_marginEnd="3dp"
            android:tag="t9_2" android:clickable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="2" android:textSize="22sp" android:textColor="@color/key_text" android:clickable="false" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="abc" android:textSize="10sp" android:textColor="@color/key_text_secondary" android:clickable="false" />
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:background="@drawable/key_bg" android:layout_marginStart="3dp" android:layout_marginEnd="3dp"
            android:tag="t9_3" android:clickable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="3" android:textSize="22sp" android:textColor="@color/key_text" android:clickable="false" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="def" android:textSize="10sp" android:textColor="@color/key_text_secondary" android:clickable="false" />
        </LinearLayout>
    </LinearLayout>

    <!-- Row 2: 4(ghi) 5(jkl) 6(mno) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp">

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:background="@drawable/key_bg" android:layout_marginStart="3dp" android:layout_marginEnd="3dp"
            android:tag="t9_4" android:clickable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="4" android:textSize="22sp" android:textColor="@color/key_text" android:clickable="false" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ghi" android:textSize="10sp" android:textColor="@color/key_text_secondary" android:clickable="false" />
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:background="@drawable/key_bg" android:layout_marginStart="3dp" android:layout_marginEnd="3dp"
            android:tag="t9_5" android:clickable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="5" android:textSize="22sp" android:textColor="@color/key_text" android:clickable="false" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="jkl" android:textSize="10sp" android:textColor="@color/key_text_secondary" android:clickable="false" />
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:background="@drawable/key_bg" android:layout_marginStart="3dp" android:layout_marginEnd="3dp"
            android:tag="t9_6" android:clickable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="6" android:textSize="22sp" android:textColor="@color/key_text" android:clickable="false" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="mno" android:textSize="10sp" android:textColor="@color/key_text_secondary" android:clickable="false" />
        </LinearLayout>
    </LinearLayout>

    <!-- Row 3: 7(pqrs) 8(tuv) 9(wxyz) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp">

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:background="@drawable/key_bg" android:layout_marginStart="3dp" android:layout_marginEnd="3dp"
            android:tag="t9_7" android:clickable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="7" android:textSize="22sp" android:textColor="@color/key_text" android:clickable="false" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="pqrs" android:textSize="10sp" android:textColor="@color/key_text_secondary" android:clickable="false" />
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:background="@drawable/key_bg" android:layout_marginStart="3dp" android:layout_marginEnd="3dp"
            android:tag="t9_8" android:clickable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="8" android:textSize="22sp" android:textColor="@color/key_text" android:clickable="false" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="tuv" android:textSize="10sp" android:textColor="@color/key_text_secondary" android:clickable="false" />
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:background="@drawable/key_bg" android:layout_marginStart="3dp" android:layout_marginEnd="3dp"
            android:tag="t9_9" android:clickable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="9" android:textSize="22sp" android:textColor="@color/key_text" android:clickable="false" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="wxyz" android:textSize="10sp" android:textColor="@color/key_text_secondary" android:clickable="false" />
        </LinearLayout>
    </LinearLayout>

    <!-- Row 4: [中/英] [0] [backspace] -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp">

        <TextView
            android:id="@+id/key_toggle"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:text="中" android:tag="toggle"
            android:textSize="16sp" android:gravity="center"
            android:background="@drawable/key_bg_dark" android:layout_marginStart="3dp" android:layout_marginEnd="3dp" android:textColor="@color/key_text_secondary" />

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:background="@drawable/key_bg" android:layout_marginStart="3dp" android:layout_marginEnd="3dp"
            android:tag="t9_0" android:clickable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0" android:textSize="22sp" android:textColor="@color/key_text" android:clickable="false" />
        </LinearLayout>

        <ImageView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:src="@drawable/ic_backspace" android:tag="backspace"
            android:scaleType="center"
            android:background="@drawable/key_bg_dark" android:layout_marginStart="3dp" android:layout_marginEnd="3dp" />
    </LinearLayout>

    <!-- Row 5: [layout] [?123] [，] [space] [。] [enter] -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:paddingStart="3dp"
        android:paddingEnd="3dp"
        android:paddingTop="3dp"
        android:paddingBottom="8dp">
        <TextView
            android:id="@+id/key_layout"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="0.9"
            android:text="26" android:tag="layout_toggle"
            android:textSize="14sp" android:gravity="center"
            android:background="@drawable/key_bg_dark" android:layout_marginStart="2.5dp" android:layout_marginEnd="2.5dp" android:textColor="@color/key_text_secondary" />
        <TextView
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:text="\?123" android:tag="num_open"
            android:textSize="13sp" android:gravity="center"
            android:background="@drawable/key_bg_dark" android:layout_marginStart="2.5dp" android:layout_marginEnd="2.5dp" android:textColor="@color/key_text_secondary" />
        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="0.9"
            android:text="，" android:tag="comma"
            android:textSize="22sp" android:gravity="center"
            android:background="@drawable/key_bg_dark" android:layout_marginStart="2.5dp" android:layout_marginEnd="2.5dp" android:textColor="@color/key_text_secondary" />
        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="3"
            android:tag="space"
            android:textSize="14sp" android:gravity="center"
            android:background="@drawable/key_bg" android:layout_marginStart="2.5dp" android:layout_marginEnd="2.5dp" android:textColor="@color/key_text_secondary" />
        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="0.9"
            android:text="。" android:tag="period"
            android:textSize="22sp" android:gravity="center"
            android:background="@drawable/key_bg_dark" android:layout_marginStart="2.5dp" android:layout_marginEnd="2.5dp" android:textColor="@color/key_text_secondary" />
        <ImageView
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.3"
            android:src="@drawable/ic_enter" android:tag="enter"
            android:scaleType="center"
            android:background="@drawable/key_bg_accent" android:layout_marginStart="2.5dp" android:layout_marginEnd="2.5dp" />
    </LinearLayout>

</LinearLayout>
