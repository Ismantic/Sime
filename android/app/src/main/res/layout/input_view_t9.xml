<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#D2D5DB">

    <!-- Preedit: pinyin interpretation of digits -->
    <TextView
        android:id="@+id/preedit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="#1A73E8"
        android:background="#FFFFFF"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:visibility="gone" />

    <!-- Candidate bar -->
    <HorizontalScrollView
        android:id="@+id/candidate_scroll"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:scrollbars="none"
        android:background="#FFFFFF">

        <LinearLayout
            android:id="@+id/candidate_container"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical" />
    </HorizontalScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#C0C0C0" />

    <!-- Row 1: 1  2(abc)  3(def) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="4dp"
        android:paddingBottom="2dp">

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:background="@drawable/key_bg" android:layout_marginStart="3dp" android:layout_marginEnd="3dp"
            android:tag="t9_1" android:onClick="onKeyPress" android:clickable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="1" android:textSize="22sp" android:textColor="#333333" android:clickable="false" />
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:background="@drawable/key_bg" android:layout_marginStart="3dp" android:layout_marginEnd="3dp"
            android:tag="t9_2" android:onClick="onKeyPress" android:clickable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="2" android:textSize="22sp" android:textColor="#333333" android:clickable="false" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="abc" android:textSize="11sp" android:textColor="#888888" android:clickable="false" />
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:background="@drawable/key_bg" android:layout_marginStart="3dp" android:layout_marginEnd="3dp"
            android:tag="t9_3" android:onClick="onKeyPress" android:clickable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="3" android:textSize="22sp" android:textColor="#333333" android:clickable="false" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="def" android:textSize="11sp" android:textColor="#888888" android:clickable="false" />
        </LinearLayout>
    </LinearLayout>

    <!-- Row 2: 4(ghi) 5(jkl) 6(mno) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp">

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:background="@drawable/key_bg" android:layout_marginStart="3dp" android:layout_marginEnd="3dp"
            android:tag="t9_4" android:onClick="onKeyPress" android:clickable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="4" android:textSize="22sp" android:textColor="#333333" android:clickable="false" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ghi" android:textSize="11sp" android:textColor="#888888" android:clickable="false" />
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:background="@drawable/key_bg" android:layout_marginStart="3dp" android:layout_marginEnd="3dp"
            android:tag="t9_5" android:onClick="onKeyPress" android:clickable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="5" android:textSize="22sp" android:textColor="#333333" android:clickable="false" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="jkl" android:textSize="11sp" android:textColor="#888888" android:clickable="false" />
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:background="@drawable/key_bg" android:layout_marginStart="3dp" android:layout_marginEnd="3dp"
            android:tag="t9_6" android:onClick="onKeyPress" android:clickable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="6" android:textSize="22sp" android:textColor="#333333" android:clickable="false" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="mno" android:textSize="11sp" android:textColor="#888888" android:clickable="false" />
        </LinearLayout>
    </LinearLayout>

    <!-- Row 3: 7(pqrs) 8(tuv) 9(wxyz) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp">

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:background="@drawable/key_bg" android:layout_marginStart="3dp" android:layout_marginEnd="3dp"
            android:tag="t9_7" android:onClick="onKeyPress" android:clickable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="7" android:textSize="22sp" android:textColor="#333333" android:clickable="false" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="pqrs" android:textSize="11sp" android:textColor="#888888" android:clickable="false" />
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:background="@drawable/key_bg" android:layout_marginStart="3dp" android:layout_marginEnd="3dp"
            android:tag="t9_8" android:onClick="onKeyPress" android:clickable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="8" android:textSize="22sp" android:textColor="#333333" android:clickable="false" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="tuv" android:textSize="11sp" android:textColor="#888888" android:clickable="false" />
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:background="@drawable/key_bg" android:layout_marginStart="3dp" android:layout_marginEnd="3dp"
            android:tag="t9_9" android:onClick="onKeyPress" android:clickable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="9" android:textSize="22sp" android:textColor="#333333" android:clickable="false" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="wxyz" android:textSize="11sp" android:textColor="#888888" android:clickable="false" />
        </LinearLayout>
    </LinearLayout>

    <!-- Row 4: [switch] [0] [backspace] -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp">

        <TextView
            android:id="@+id/key_toggle"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:text="中" android:tag="toggle" android:onClick="onKeyPress"
            android:textSize="16sp" android:gravity="center"
            android:background="@drawable/key_bg_dark" android:layout_marginStart="3dp" android:layout_marginEnd="3dp" android:textColor="#333333" />

        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:text="0" android:tag="t9_0" android:onClick="onKeyPress"
            android:textSize="22sp" android:gravity="center"
            android:background="@drawable/key_bg" android:layout_marginStart="3dp" android:layout_marginEnd="3dp" android:textColor="#333333" />

        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:text="⌫" android:tag="backspace" android:onClick="onKeyPress"
            android:textSize="22sp" android:gravity="center"
            android:background="@drawable/key_bg_dark" android:layout_marginStart="3dp" android:layout_marginEnd="3dp" android:textColor="#333333" />
    </LinearLayout>

    <!-- Row 5: [keyboard] [，] [space] [。] [enter] -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:paddingStart="3dp"
        android:paddingEnd="3dp"
        android:paddingTop="2dp"
        android:paddingBottom="6dp">
        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.2"
            android:text="26" android:tag="switch_kb" android:onClick="onKeyPress"
            android:textSize="14sp" android:gravity="center"
            android:background="@drawable/key_bg_dark" android:layout_marginStart="2dp" android:layout_marginEnd="2dp" android:textColor="#333333" />
        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:text="，" android:tag="comma" android:onClick="onKeyPress"
            android:textSize="20sp" android:gravity="center"
            android:background="@drawable/key_bg_dark" android:layout_marginStart="2dp" android:layout_marginEnd="2dp" android:textColor="#333333" />
        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="3.5"
            android:text="空格" android:tag="space" android:onClick="onKeyPress"
            android:textSize="18sp" android:gravity="center"
            android:background="@drawable/key_bg" android:layout_marginStart="2dp" android:layout_marginEnd="2dp" android:textColor="#333333" />
        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:text="。" android:tag="period" android:onClick="onKeyPress"
            android:textSize="20sp" android:gravity="center"
            android:background="@drawable/key_bg_dark" android:layout_marginStart="2dp" android:layout_marginEnd="2dp" android:textColor="#333333" />
        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5"
            android:text="确认" android:tag="enter" android:onClick="onKeyPress"
            android:textSize="16sp" android:gravity="center"
            android:background="@drawable/key_bg_accent" android:layout_marginStart="2dp" android:layout_marginEnd="2dp" android:textColor="#FFFFFF" />
    </LinearLayout>

</LinearLayout>
