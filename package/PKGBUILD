pkgname=fcitx5-sime
pkgver=r78.5559fa5
pkgrel=1
pkgdesc="Sime Chinese input method for Fcitx5"
arch=("x86_64")
url="https://github.com/Ismantic/Sime"
license=("custom")
depends=("fcitx5")
makedepends=("cmake" "gcc" "make")
source=("sime::git+file:///home/tfbao/Isma/Sime")
sha256sums=("SKIP")

pkgver() {
  cd "$srcdir/sime"
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

build() {
  cmake -S "$srcdir/sime" -B "$srcdir/build" \
    -DCMAKE_BUILD_TYPE=Release \
    -DSIME_ENABLE_FCITX5=ON
  cmake --build "$srcdir/build"
}

package() {
  DESTDIR="$pkgdir" cmake --install "$srcdir/build"

  # 安装数据文件
  install -dm755 "$pkgdir/usr/share/sime"
  install -m644 "$srcdir/sime/dict/trie.bin"  "$pkgdir/usr/share/sime/trie.bin"
  install -m644 "$srcdir/sime/dict/model.bin" "$pkgdir/usr/share/sime/model.bin"
}
