<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/keyboard_bg">

    <!-- Category tabs -->
    <HorizontalScrollView
        android:id="@+id/symbol_tabs_scroll"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:scrollbars="none"
        android:background="@color/candidate_bg">
        <LinearLayout
            android:id="@+id/symbol_tabs"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="4dp" />
    </HorizontalScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/candidate_divider" />

    <!-- Symbol grid: 4 rows x 6 cols = 24 symbols per page -->
    <LinearLayout
        android:id="@+id/symbol_grid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp" />

    <!-- Bottom bar: [返回] [page indicator] [backspace] -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:orientation="horizontal"
        android:paddingStart="3dp"
        android:paddingEnd="3dp"
        android:paddingTop="3dp"
        android:paddingBottom="8dp">
        <TextView
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5"
            android:text="返回" android:tag="sym_back"
            android:textSize="14sp" android:gravity="center"
            android:background="@drawable/key_bg_dark" android:layout_marginStart="2.5dp" android:layout_marginEnd="2.5dp" android:textColor="@color/key_text_secondary" />
        <TextView
            android:id="@+id/sym_page_indicator"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="4"
            android:gravity="center"
            android:textSize="12sp" android:textColor="@color/key_text_secondary" />
        <ImageView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5"
            android:src="@drawable/ic_backspace" android:tag="backspace"
            android:scaleType="center"
            android:background="@drawable/key_bg_dark" android:layout_marginStart="2.5dp" android:layout_marginEnd="2.5dp" />
    </LinearLayout>

</LinearLayout>
